# Required for the agentic layer
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=postgresql://amrsentinel:amrsentinel_dev@localhost:5432/amrsentinel

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
SCHEMA_REGISTRY_URL=http://localhost:8081

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=amrsentinel_dev

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# JWT
JWT_SECRET=dev-secret-key-change-in-production-min-256-bits-long-required

# Service URLs
INGESTION_SERVICE_URL=http://localhost:8001
INTELLIGENCE_SERVICE_URL=http://localhost:8002
AGENTIC_SERVICE_URL=http://localhost:8003
